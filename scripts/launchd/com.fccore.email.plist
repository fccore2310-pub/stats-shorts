<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.fccore.email</string>

    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/opt/python@3.13/libexec/bin/python3</string>
        <string>/Users/fatimaabajo/Desktop/Shorts-Reels/scripts/email_report.py</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/fatimaabajo/Desktop/Shorts-Reels</string>

